# Secrets never enter git. .env.* is ignored, but the negation keeps
# .env.example tracked so the variable names stay documented in the repo.
.env
.env.*
!.env.example

secrets/

__pycache__/
*.pyc

.DS_Store

backups/

# Source-of-truth content lives in projects/webapp/; this doc bundle is a local
# working copy (design spec, French translation, roadmap, handoff notes) and a
# duplicate of index.html/resume/ kept around for reference, not tracked in git.
infrastructure/docs/webapp_doc/

# Machine-local Claude Code permission state, not shared config.
.claude/settings.local.json
