# Traefik dashboard basic-auth (htpasswd format: user:hash)
# Generate your own hash: openssl passwd -apr1 'your-password'
# Then set: TRAEFIK_DASHBOARD_AUTH=<user>:<hash>  (escape $ as $$ for docker-compose)
TRAEFIK_DASHBOARD_AUTH=

# Grafana admin password (CP5 — set before starting the monitoring stack)
GF_SECURITY_ADMIN_PASSWORD=
